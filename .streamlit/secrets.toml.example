# Copy this file to .streamlit/secrets.toml (gitignored) and set a real
# passphrase before running the app. This gates every page in app/ — see
# app/auth.py. Rotate this whenever the chief resident role changes hands.
#
# After copying, tighten permissions so other local accounts on the
# workstation can't read it: chmod 600 .streamlit/secrets.toml

chief_passphrase = "change-me"
